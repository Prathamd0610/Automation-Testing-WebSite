# ──────────────────────────────────────────────────────────────────────────────
# EXAMPLE environment file — placeholders only, safe to commit to GitHub.
# Copy the real values into git-ignored files (never commit them):
#   • server/.env  — local backend dev
#   • client/.env  — local frontend dev
# For Render (backend) and Vercel (frontend), set these in each dashboard instead.
# ──────────────────────────────────────────────────────────────────────────────

# ── Shared ───────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# MongoDB Atlas (recommended — used by Render). Replace the username, password
# and cluster host with your own; keep the /automation_practice database name.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/automation_practice?retryWrites=true&w=majority&appName=Cluster0
# Local Docker alternative (only if you run docker-compose):
# MONGODB_URI=mongodb://admin:changeme_local_password@mongo:27017/automation_practice?authSource=admin

JWT_SECRET=replace_with_a_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Local: http://localhost:5173 — on Render set this to your Vercel URL.
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info
MAX_UPLOAD_BYTES=5242880

# ── MongoDB (only for the optional local docker-compose service) ──────────────
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=changeme_local_password
MONGO_INITDB_DATABASE=automation_practice

# ── Client (build-time, injected by Vite) ────────────────────────────────────
# Local: points at the local API. On Vercel set this to your Render URL + /api,
# e.g. https://your-api.onrender.com/api
VITE_API_URL=http://localhost:5000/api
VITE_APP_NAME=Automation Testing Practice Platform
VITE_ENVIRONMENT=development
# Google AdSense publisher id (ca-pub-...). Leave blank to show ad placeholders.
VITE_ADSENSE_CLIENT=
