# ── Server environment ────────────────────────────────────────────────────────
# Copy to `server/.env` for local development (without Docker).

NODE_ENV=development
PORT=5000

# Local MongoDB (run `docker compose up mongo` or a local mongod).
MONGODB_URI=mongodb://localhost:27017/automation_practice

# Secrets — generate long random strings (e.g. `openssl rand -hex 48`).
JWT_SECRET=replace_with_a_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS / cookies origin.
FRONTEND_URL=http://localhost:5173

# Logging level: error | warn | info | http | debug
LOG_LEVEL=info

# Max upload size in bytes (default 5 MB).
MAX_UPLOAD_BYTES=5242880
